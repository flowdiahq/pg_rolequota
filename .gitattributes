# pg_rolequota .gitattributes
# Enforce LF line endings for all source files (matches PostgreSQL core style)

* text=auto

# Source code and build files - force LF
*.c text eol=lf
*.h text eol=lf
*.sql text eol=lf
Makefile text eol=lf
*.mk text eol=lf
*.sh text eol=lf

# Documentation and configuration
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.conf text eol=lf
*.control text eol=lf

# Special files
LICENSE text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
CHANGELOG* text eol=lf
CONTRIBUTING* text eol=lf
CODE_OF_CONDUCT* text eol=lf
SECURITY* text eol=lf
